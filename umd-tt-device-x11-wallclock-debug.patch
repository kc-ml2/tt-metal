+bool profiler_debug_x11_enabled() {
+    const char* value = std::getenv("TT_METAL_PROFILER_DEBUG_X11");
+    return value != nullptr && std::string_view(value) == "1";
+}
+
+bool profiler_debug_x11_translated_core(tt_xy_pair core) {
+    return (core.x == 6 || core.x == 7 || core.x == 10) && (core.y == 2 || core.y == 10 || core.y == 11);
+}
+
+void log_profiler_debug_x11_reset_regs(
+    TTDevice& device,
+    tt_xy_pair core,
+    std::string_view phase,
+    uint32_t current_state,
+    uint32_t update_state,
+    uint32_t target_state) {
+    if (!profiler_debug_x11_enabled() || device.get_arch() != tt::ARCH::BLACKHOLE ||
+        !profiler_debug_x11_translated_core(core)) {
+        return;
+    }
+
+    constexpr uint64_t soft_reset_addr = 0xFFB121B0;
+    constexpr uint64_t wall_clock_0_addr = 0xFFB121F0;
+    constexpr uint64_t wall_clock_1_addr = 0xFFB121F4;
+    constexpr uint64_t wall_clock_1_at_addr = 0xFFB121F8;
+    uint32_t soft_reset_readback = 0;
+    uint32_t wall0 = 0;
+    uint32_t wall1 = 0;
+    uint32_t wall1_at = 0;
+
+    device.read_from_device(&soft_reset_readback, core, soft_reset_addr, sizeof(soft_reset_readback));
+    device.read_from_device(&wall0, core, wall_clock_0_addr, sizeof(wall0));
+    device.read_from_device(&wall1, core, wall_clock_1_addr, sizeof(wall1));
+    device.read_from_device(&wall1_at, core, wall_clock_1_at_addr, sizeof(wall1_at));
+
+    log_info(
+        tt::LogDevice,
+        "PROFILER_DEBUG_X11 umd_reset_clock phase={} translated=({},{}) current=0x{:08x} update=0x{:08x} target=0x{:08x} soft_reset_readback=0x{:08x} wall0_low=0x{:08x} wall1_raw=0x{:08x} wall1_at=0x{:08x}",
+        phase,
+        core.x,
+        core.y,
+        current_state,
+        update_state,
+        target_state,
+        soft_reset_readback,
+        wall0,
+        wall1,
+        wall1_at);
+}
+
+void log_profiler_debug_x11_physical_sample_cores(TTDevice& device, std::string_view phase) {
+    if (!profiler_debug_x11_enabled() || device.get_arch() != tt::ARCH::BLACKHOLE) {
+        return;
+    }
+
+    constexpr uint64_t soft_reset_addr = 0xFFB121B0;
+    constexpr uint64_t wall_clock_0_addr = 0xFFB121F0;
+    constexpr uint64_t wall_clock_1_addr = 0xFFB121F4;
+    constexpr uint64_t wall_clock_1_at_addr = 0xFFB121F8;
+
+    for (uint32_t y : {2u, 10u, 11u}) {
+        for (const auto& [translated_x, physical_x] :
+             {std::pair<uint32_t, uint32_t>{6u, 6u},
+              std::pair<uint32_t, uint32_t>{7u, 11u},
+              std::pair<uint32_t, uint32_t>{10u, 12u}}) {
+            tt_xy_pair translated_core(translated_x, y);
+            uint32_t soft_reset_readback = 0;
+            uint32_t wall0 = 0;
+            uint32_t wall1 = 0;
+            uint32_t wall1_at = 0;
+            device.read_from_device(
+                &soft_reset_readback, translated_core, soft_reset_addr, sizeof(soft_reset_readback));
+            device.read_from_device(&wall0, translated_core, wall_clock_0_addr, sizeof(wall0));
+            device.read_from_device(&wall1, translated_core, wall_clock_1_addr, sizeof(wall1));
+            device.read_from_device(&wall1_at, translated_core, wall_clock_1_at_addr, sizeof(wall1_at));
+            log_info(
+                tt::LogDevice,
+                "PROFILER_DEBUG_X11 umd_open_clock phase={} device_id={} translated=({},{}) physical=({},{}) soft_reset_readback=0x{:08x} wall0_low=0x{:08x} wall1_raw=0x{:08x} wall1_at=0x{:08x}",
+                phase,
+                device.get_communication_device_id(),
+                translated_x,
+                y,
+                physical_x,
+                y,
+                soft_reset_readback,
+                wall0,
+                wall1,
+                wall1_at);
+        }
+    }
+}
+
